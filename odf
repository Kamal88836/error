  namespace: openshift-storage
spec:
  config: '{
    "cniVersion": "0.3.1",
    "type": "macvlan",
    "master": "ens4f1",
    "mode": "bridge",
    "ipam": {
      "type": "whereabouts",
      "range": "10.200.63.0/24",
