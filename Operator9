🚀 🔥 COMPLETE ODF CLEANUP SCRIPT (Safe + Working)

⚠️ Run from a node with oc login done

#!/bin/bash

echo "🚨 Starting ODF FULL CLEANUP..."

# 1️⃣ Delete subscriptions
echo "👉 Deleting subscriptions..."
oc delete subscription -n openshift-storage --all --ignore-not-found=true

# 2️⃣ Delete InstallPlans
echo "👉 Deleting installplans..."
oc delete installplan -n openshift-storage --all --ignore-not-found=true

# 3️⃣ Delete CSVs
echo "👉 Deleting CSVs..."
oc delete csv -n openshift-storage --all --ignore-not-found=true

# 4️⃣ Delete StorageCluster
echo "👉 Deleting StorageCluster..."
oc get storagecluster -n openshift-storage -o name | xargs -r oc delete -n openshift-storage

# 5️⃣ Delete CephCluster
echo "👉 Deleting CephCluster..."
oc get cephcluster -n openshift-storage -o name | xargs -r oc delete -n openshift-storage

# 6️⃣ Delete NooBaa
echo "👉 Deleting NooBaa..."
oc get noobaa -n openshift-storage -o name | xargs -r oc delete -n openshift-storage

# 7️⃣ Delete all resources in namespace
echo "👉 Cleaning namespace..."
oc delete all --all -n openshift-storage --ignore-not-found=true
oc delete pvc --all -n openshift-storage --ignore-not-found=true
oc delete secret --all -n openshift-storage --ignore-not-found=true
oc delete configmap --all -n openshift-storage --ignore-not-found=true

# 8️⃣ Delete CRDs (ODF related)
echo "👉 Deleting CRDs..."
oc get crd | grep -E 'ceph|rook|ocs|odf' | awk '{print $1}' | xargs -r oc delete crd

# 9️⃣ Restart marketplace (OLM refresh)
echo "👉 Restarting CatalogSource..."
oc delete pod -n openshift-marketplace -l olm.catalogSource=cs-redhat-operator-index-v4-19

echo "✅ CLEANUP COMPLETED"


