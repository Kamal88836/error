[root@bastion templates]# cat bip-sriov-net.yaml
{{- $nameSuffix := "" }}
{{- if and (.Values.second_bscf) (ne .Values.second_bscf "disable") }}
{{- $nameSuffix = printf "-%s" .Values.namespace }}
{{- end }}

{{- if eq .Values.platform "ocp" }}

apiVersion: sriovnetwork.openshift.io/v1
kind: SriovNetwork
metadata:
  name: bscf-bh0c-nad{{ $nameSuffix }}
  namespace: openshift-sriov-network-operator
spec:
  networkNamespace: {{ $.Values.namespace }}
  ipam: "{}"
  capabilities: '{ "mac": true, "ips": true }'
  {{- if eq ( .Values.sriov.networkType | lower ) "vlan" }}
  vlan: {{ .Values.sriov.bip.bh0c }}
  {{- else }}
  vlan: 0
  {{- end }}
  resourceName: pci_sriov_net_bh0c
  spoofChk: 'on'
  trust: 'on'
  inkState: auto
---
apiVersion: sriovnetwork.openshift.io/v1
kind: SriovNetwork
metadata:
  name: bscf-bh0c-1-nad{{ $nameSuffix }}
  namespace: openshift-sriov-network-operator
spec:
  networkNamespace: {{ $.Values.namespace }}
  ipam: "{}"
  capabilities: '{ "mac": true, "ips": true }'
  {{- if eq ( .Values.sriov.networkType | lower ) "vlan" }}
  vlan: {{ .Values.sriov.bip.bh0c_1 }}
  {{- else }}
  vlan: 0
  {{- end }}
  resourceName: pci_sriov_net_bh0c_1
  spoofChk: 'on'
  trust: 'on'
  inkState: auto
---
{{- if eq ($.Values.targetFlavor|lower) "tiny-2u-t1" }}
apiVersion: sriovnetwork.openshift.io/v1
kind: SriovNetwork
metadata:
  name: bscf-bh0c-2-nad{{ $nameSuffix }}
  namespace: openshift-sriov-network-operator
spec:
  networkNamespace: {{ $.Values.namespace }}
  ipam: "{}"
  capabilities: '{ "mac": true, "ips": true }'
  {{- if eq ( .Values.sriov.networkType | lower ) "vlan" }}
  vlan: {{ .Values.sriov.bip.bh0c_2 }}
  {{- else }}
  vlan: 0
  {{- end }}
  resourceName: pci_sriov_net_bh0c_2
  trust: 'on'
  inkState: auto
---
apiVersion: sriovnetwork.openshift.io/v1
kind: SriovNetwork
metadata:
  name: bscf-bh0c-2-1-nad{{ $nameSuffix }}
  namespace: openshift-sriov-network-operator
spec:
  networkNamespace: {{ $.Values.namespace }}
  ipam: "{}"
  capabilities: '{ "mac": true, "ips": true }'
  {{- if eq ( .Values.sriov.networkType | lower ) "vlan" }}
  vlan: {{ .Values.sriov.bip.bh0c_2_1 }}
  {{- else }}
  vlan: 0
  {{- end }}
  resourceName: pci_sriov_net_bh0c_2_1
  trust: 'on'
  inkState: auto
---
{{- end }}
---
apiVersion: "k8s.cni.cncf.io/v1"
kind: NetworkAttachmentDefinition
metadata:
  name: bscf-bond-nad{{ $nameSuffix }}
  namespace: {{ $.Values.namespace }}
spec:
  config: '{
  "type": "bond",
  "cniVersion": "0.3.1",
  "name": "bh0",
  "ifname": "bh0",
  "mode": "active-backup",
  "failOverMac": 1,
  "linksInContainer": true,
  "miimon": "100",
  "mtu": 1500,
  "links": [
     {"name": "bh0_0"},
     {"name": "bh0_1"}
  ]
}'
---
{{- else }}

{{- with .Values.sriov.bip }}
{{- range $interface, $vlanId := . }}
apiVersion: "k8s.cni.cncf.io/v1"
kind: NetworkAttachmentDefinition
metadata:
  namespace: {{ $.Values.namespace }}
  {{- if eq $interface "bh0c_1" }}
  name: {{ $.Values.neType }}-bh0c-1-nad{{ $nameSuffix }}
  {{- else }}
  name: {{ $.Values.neType }}-{{ $interface }}-nad{{ $nameSuffix }}
  {{- end }}
  labels:
    {{- if eq $interface "bh0c_1" }}
    app: {{ $.Values.neType }}-bh0c-1-nad
    {{- else }}
    app: {{ $.Values.neType }}-{{ $interface }}-nad
    {{- end }}
  annotations:
    k8s.v1.cni.cncf.io/resourceName: {{ $.Values.sriov.devicePrefix }}/pci_sriov_net_{{ $interface }}
spec:
  config: '{
    "cniVersion": "0.3.0",
    "type": "sriov",
    {{- if and ( eq ( $.Values.sriov.networkType | lower ) "vlan" ) }}
    "vlan": {{ $vlanId }},
    {{- else }}
    "vlan": 0,
    {{- end }}
    "trust": "on"
  }'
---
{{- end }}
apiVersion: "k8s.cni.cncf.io/v1"
kind: NetworkAttachmentDefinition
metadata:
  namespace: {{ $.Values.namespace }}
  name: {{ $.Values.neType }}-bond-nad{{ $nameSuffix }}
  labels:
    app: {{ $.Values.neType }}-bond-nad
spec:
  config: '{
    "type": "bond",
    "cniVersion": "0.3.0",
    "name": "bh0",
    "mode": "active-backup",
    "failOverMac": 1,
    "linksInContainer": true,
    "miimon": "100",
    "mtu": 1500,
    "links": [
       {"name": "bh0_0"},
       {"name": "bh0_1"}
    ]
  }'
---
{{- end }}

{{- end }}



