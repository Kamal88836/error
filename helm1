[root@bastion bscf-pre]# cat values.yaml
# Default values for bscf-pre.
# This is a YAML-formatted file.
# Declare variables to be passed into your templates.

#################################################################
# Operator configuration.
#################################################################

namespace: "default"
second_bscf: "disable" # disable for sno and enable for 2nd bscf feature
neType: "bscf"
accessPolicy: "limited" # "limited, full"
platform: "ocp" # "wrcp or ocp or aws"
targetFlavor: ""
# The vlan id of the sriov interface must be set according to the network environment to be installed.
sriov:
  devicePrefix: "intel.com"
  networkType: "flat" # "flat or vlan"
  bpp:
    bh0u: "71"       #vlan id if networkType is vlan
    bh0u_1: "71"     #vlan id if networkType is vlan
    bh0u_2: "71"      #vlan id if networkType is vlan
    bh0u_2_1: "71"    #vlan id if networkType is vlan
    bh0u_3: "71"    #vlan id if networkType is vlan
    bh0u_3_1: "71"    #vlan id if networkType is vlan
  bip:
    bh0c: "71"       #vlan id if networkType is vlan
    bh0c_1: "71"     #vlan id if networkType is vlan
