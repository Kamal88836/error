                    container twamp-reflector-config {
                      if-feature "fp:f_TWAMP";
                      must 'min-udp-port <= max-udp-port' {
                        error-message "min-udp-port should be smaller than or equal to max-udp-port";
                      }
                      description
                        "This container manages the configuration settings of the reflector to provide Two-Way Active Measurement Protocol (TWAMP) function. The TWAMP reflector accepts or denies TWAMP client requests through the well-known 862 port. The container manages the operation policy on the TWAMP reflector side during the test.";
                      common:common-description-kor "This container manages the configuration of reflectors to provide Two-Way Active Measurement Protocol (TWAMP) functionality. The TWAMP Reflector allows or rejects requests from the TWAMP client over the well-known 862 port. This setting manages the operating policy on the TWAMP reflector side when performing tests.";
                      tailf:validate v_twamp-reflector-config {
                          tailf:opaque "twamp-reflector-config";
                          tailf:dependency ".";
                      }
