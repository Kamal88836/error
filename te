apiVersion: v1
#######################
# Cluster information #
#######################
## 향후 Cluster접속시 <metadata.name>.<baseDomain> 으로 접속하게 됩니다.
baseDomain: "" # ex) samsung.local
## SNO의 경우 vDU 생성을 위해 아래 주석을 삭제하여 Workload partitioning을 설정해야 합니다.(Single-node OpenShift clusters that run DU workloads require workload partitioning. This limits the cores allowed to run platform services, maximizing the CPU core for application payloads. Workload partitioning can be enabled during cluster installation only. You cannot disable workload partitioning postinstallation. )
#cpuPartitioningMode: AllNodes
metadata:
## It should be unique with the project name.
  name: "" # Cluster Name ex) sno-xxx, mno-xxx

## cat ~/.ssh/id_rsa.pub
## 들여쓰기 2칸을 해주셔야 합니다. ssh-rsa 포함하여서 작성해주세요
## 특수문자 ''(작은따옴표)나 ""(큰따옴표)를 포함하지 않으셔야 합니다
## 아래는 예시입니다
## sshKey: |
##   ssh-rsa  root@C61U35
## Cluster별로 별도 Linux계정을 사용할경우 모든 계정의 sshKey값을 넣어주세요
## 아래는 예시입니다
## sshKey: |
##   ssh-rsa  root@C61U35
##   ssh-rsa  root@bastion.ss1.samsung.local
sshKey: |
  ssh-rsa AAAAA.....

compute:
- hyperthreading: Enabled 
  name: worker
## 초기 설치시 포함되는 worker의 개수를 적어주셔야 합니다
  replicas: 0
controlPlane:
  hyperthreading: Enabled 
  name: master
## 설치시 포함되는 master의 개수를 적어주셔야 합니다
  replicas: 3 # SNO=1, MNO=3
platform:
## SNO의 경우 platform의 값은 none입니다.
#  none: {}
## MNO의 경우 paltform에 api들이 포함되어야 합니다.
  baremetal:
    apiVIPs:
## IPv4
    - "" # ex) 172.20.221.35
## IPv6
#    - "" # ex) 2001:dc2:b00:2021:172:20:221:34
    ingressVIPs:
## IPv4
    - "" # ex) 172.20.221.36
## IPv6
#    - "" # ex) 2001:dc2:b00:2021:172:20:221:35

fips: false

###############################
# Cluster Network information #
###############################
networking:
## Single-stack(IPv4): IPv4에 설정된 값을 변경해주세요
## Single-stack(IPv6): IPv4의 값들을 주석처리하고 IPv6에 있는 값 주석을 풀어주세요
## Dual-stack: IPv4, IPv6 모두 설정되어있어야 합니다
## 아래값은 모두 defualt값으로 필요시에만 변경해주세요

### Warning ###
## MachineNetwork 는 필수로 적혀있어야 합니다
## MachineNetwork CIDR 제약사항으로 아래 IP 대역을 사용 불가능합니다.
### https://en.m.wikipedia.org/wiki/Reserved_IP_addresses

## The IP address block for pods
  clusterNetwork:
## IPv4
  - cidr: "10.128.0.0/14"
    hostPrefix: "24"
## IPv6
#  - cidr: "fd02::/48"
#    hostPrefix: "64"

  networkType: OVNKubernetes

## The IP address block for services
  serviceNetwork:
## IPv4
  - "172.30.0.0/16"
## IPv6
#  - "fd03::/112"

## The IP address block for nodes includes all masters and workers
  machineNetwork:
## IPv4
  - cidr: "" # ex)172.20.221.0/24
## IPv6
#  - cidr: "" # ex)2001:dc2:b00:2021::/64

